#include <iostream>
#include <vector>
#include <queue>
using namespace std;

typedef pair<int, int> pii;

// Function to find MST using Prim's Algorithm
void primMST(int V, vector<vector<pii>> &adj) {
    priority_queue<pii, vector<pii>, greater<pii>> pq;
    vector<bool> inMST(V, false);

    int totalCost = 0;

    // Start from node 0 (weight, node)
    pq.push({0, 0});

    while (!pq.empty()) {
        int weight = pq.top().first;
        int u = pq.top().second;
        pq.pop();

        // Skip if already included
        if (inMST[u]) continue;

        inMST[u] = true;
        totalCost += weight;

        // Traverse neighbors
        for (auto &neighbor : adj[u]) {
            int v = neighbor.first;
            int w = neighbor.second;

            if (!inMST[v]) {
                pq.push({w, v});
            }
        }
    }

    cout << "Total weight of MST: " << totalCost << endl;
}

int main() {
    int V = 5; // Number of vertices
    vector<vector<pii>> adj(V);

    // Add edges: (u, v, weight)
    adj[0].push_back({1, 2});
    adj[1].push_back({0, 2});

    adj[0].push_back({3, 6});
    adj[3].push_back({0, 6});

    adj[1].push_back({2, 3});
    adj[2].push_back({1, 3});

    adj[1].push_back({3, 8});
    adj[3].push_back({1, 8});

    adj[1].push_back({4, 5});
    adj[4].push_back({1, 5});

    adj[2].push_back({4, 7});
    adj[4].push_back({2, 7});

    primMST(V, adj);

    return 0;
}
